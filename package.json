{
  "name": "maze-adventure",
  "version": "2.1.0",
  "description": "Maze Adventure desktop build",
  "main": "main.js",
  "author": "OpenAI Codex",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "pack:win": "electron-builder --win portable nsis",
    "pack:mac": "electron-builder --mac dir zip"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.codex.mazeadventure",
    "productName": "\u8ff7\u5bae\u5192\u96aa ver.2.1.0",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "styles.css",
      "game.js",
      "main.js",
      "package.json"
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dir",
        "zip"
      ],
      "category": "public.app-category.games"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
